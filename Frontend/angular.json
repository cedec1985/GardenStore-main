{
  "$schema": "node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "cli": {
    "analytics": false,
    "packageManager": "npm"
  },
  "projects": {
    "mon-app": {
      "projectType": "application",
      "root": "",
      "sourceRoot": "Frontend",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:browser",
          "options": {
            "outputPath":"dist",
            "main":"main.ts",
            "tsConfig": "../tsconfig.app.json",
            "assets": [{
              "glob":"**/*",
              "input" : "public"
            },
            {
              "glob": "**/*",
              "input": "Frontend/app/assets",
              "output" : "/assets"
            }]
            ,
            "styles": ["styles.css",
            "node_modules/@fortawesome/fontawesome-free/css/all.min.css"
          ],
            "index":"index.html",
            "scripts": []
          },
          "configurations": {
            "production": {
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.prod.ts"
                }
              ],
              "optimization": true,
              "outputHashing": "all",
              "sourceMap": false,
              "namedChunks": false,
              "extractLicenses": true
            },
            "development": {
              "optimization": false,
              "outputHashing": "none",
              "sourceMap": true,
              "namedChunks": true

            }
          },
          "defaultConfiguration": "development"
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "options": {
            "buildTarget": "mon-app:build"
          },
          "configurations": {
            "production": {
              "buildTarget": "mon-app:build:production"
            },
            "development": {
              "buildTarget": "mon-app:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "test": {
          "builder": "@angular/build:unit-test",
          "options": {
            "polyfills": [
              "zone.js",
              "zone.js/testing",
              "polyfills.ts"
            ],
            "main": "test.ts",
            "tsConfig": "../tsconfig.spec.json",
            "karmaConfig": "karma.conf.js",
            "assets": [ "Frontend/app/assets"],
            "styles": ["styles.css"],
            "scripts": [],
            "karma":"karma.conf.js",
            "runner":"karma"
          }
        },
        "lint": {
          "builder": "@angular-eslint/builder:lint",
          "options": {
            "lintFilePatterns": ["src/**/*.ts", "src/**/*.html"]
          }
        }
  }
}
  }}
